root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 140
ktlint_code_style = intellij_idea

# Compose composables use PascalCase, which clashes with ktlint's default function naming.
ktlint_standard_function-naming = disabled

# Allow trailing commas for clean multi-line argument formatting.
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Disable overly strict rules that conflict with this codebase's layout.
ktlint_standard_no-wildcard-imports = disabled
ktlint_standard_property-naming = disabled

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
