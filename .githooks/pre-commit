#!/bin/sh
#
# Pre-commit hook: runs ktlint on staged Kotlin files.
# Fails the commit if any style violations are found.
#
# Install once after cloning:
#     git config core.hooksPath .githooks
#

set -e

# Only run when Kotlin files are staged
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.kts?$' || true)
if [ -z "$STAGED_KT_FILES" ]; then
    exit 0
fi

echo "Running ktlint on staged Kotlin files..."
./gradlew --quiet ktlintCheck

echo "ktlint passed."
